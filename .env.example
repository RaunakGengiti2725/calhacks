# DryRun environment configuration.
# Copy to `.env` and fill in keys ONLY if you want DRYRUN_MODE=live.
# The entire app runs end to end with the defaults below (mock mode, no keys).

# ----------------------------------------------------------------------------
# Global mode switch. The single lever that selects Mock vs Live providers.
#   mock = realistic synthetic data, instant, no network, no credentials.
#   live = call the real external APIs (each falls back to mock on any failure).
# ----------------------------------------------------------------------------
DRYRUN_MODE=mock

# ----------------------------------------------------------------------------
# ASI:One (the LLM used by the orchestrator for intent parsing + summaries).
# OpenAI-Chat-Completions compatible. Only read in live mode.
# ----------------------------------------------------------------------------
ASI_ONE_API_KEY=
ASI_ONE_BASE_URL=https://api.asi1.ai/v1
ASI_ONE_MODEL=asi1-mini

# ----------------------------------------------------------------------------
# NVIDIA NIM (Evo 2 for sequence viability + generative design,
# AlphaFold2 for structure prediction). Only read in live mode.
# ----------------------------------------------------------------------------
NVIDIA_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
EVO2_MODEL=arc/evo2-40b
ALPHAFOLD2_URL=https://health.api.nvidia.com/v1/biology/deepmind/alphafold2/predict-structure-from-sequence

# ----------------------------------------------------------------------------
# Live-folding scoping. Full MSA-based AlphaFold2 is slow/compute-heavy, so the
# live structure path only folds viability survivors and caps the count.
# ----------------------------------------------------------------------------
DRYRUN_FOLD_CAP=4

# ----------------------------------------------------------------------------
# API gateway / frontend wiring.
# ----------------------------------------------------------------------------
DRYRUN_API_PORT=8000
NEXT_PUBLIC_DRYRUN_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Agentverse / Almanac registration (Phase 5). Optional; demo runs without them.
# ----------------------------------------------------------------------------
AGENTVERSE_API_KEY=
DRYRUN_AGENT_SEED=
