# DryRun environment configuration.
# Copy to `.env` and fill in keys ONLY if you want DRYRUN_MODE=live.
# The entire app runs end to end with the defaults below (mock mode, no keys).
#
# The app loads this file automatically on startup (see dryrun_providers/config.py),
# so pasted keys take effect with no extra step. Precedence: a variable already set
# in your shell wins over .env, which wins over the in-code default.
#
# Where to get each key and how to register the agents: see SETUP.md.

# ----------------------------------------------------------------------------
# Global mode switch — the single lever that selects Mock vs Live providers.
#   mock = realistic synthetic data, instant, no network, no credentials.
#   live = call the real external APIs (each falls back to mock on any failure,
#          and that fallback is shown per-stage in the UI — never hidden).
# ----------------------------------------------------------------------------
DRYRUN_MODE=mock

# When set (1/true), a LIVE provider failure RAISES instead of falling back to
# mock. Use this to GUARANTEE a run is 100% real external data with nothing
# silently substituted. Leave empty for the robust demo default.
DRYRUN_STRICT=

# ----------------------------------------------------------------------------
# ASI:One — the LLM used by the orchestrator for intent parsing + summaries.
# OpenAI-Chat-Completions compatible. Get a key at https://asi1.ai (Developer →
# API Keys). Only read in live mode.
# ----------------------------------------------------------------------------
ASI_ONE_API_KEY=
ASI_ONE_BASE_URL=https://api.asi1.ai/v1
ASI_ONE_MODEL=asi1-mini

# ----------------------------------------------------------------------------
# NVIDIA NIM — biology models. Get a key (prefixed `nvapi-`) at
# https://build.nvidia.com (free developer tier with credits). Only read in live
# mode.
#
#   * Evo 2 (arc/evo2-40b)  — a GENOMIC (DNA) foundation model. DryRun uses it for
#     sequence viability (forward-pass DNA likelihood) and variant generation;
#     proteins are back-translated to DNA first (see live/_dna.py). This bridge is
#     documented but UNVERIFIED until you add a key and test it.
#   * AlphaFold2            — structure prediction (returns a PDB with per-residue
#     pLDDT). The hosted endpoint is async: POST -> 202 + nvcf-reqid -> poll the
#     status URL until 200 (handled in live/structure.py).
#
# The biology NIMs live on the health.* host (NOT integrate.api.nvidia.com, which
# serves the LLMs).
# ----------------------------------------------------------------------------
NVIDIA_API_KEY=
NVIDIA_NIM_BASE_URL=https://health.api.nvidia.com/v1
EVO2_MODEL=arc/evo2-40b
ALPHAFOLD2_URL=https://health.api.nvidia.com/v1/biology/deepmind/alphafold2/predict-structure-from-sequence
# Status endpoint polled for async (202) NVCF jobs like AlphaFold2.
NVCF_STATUS_URL=https://health.api.nvidia.com/v1/status

# ----------------------------------------------------------------------------
# Live-folding scoping. Full MSA-based AlphaFold2 is slow (minutes/seq), so the
# live structure path only folds viability survivors and caps the count. Keep
# this small for live demos.
# ----------------------------------------------------------------------------
DRYRUN_FOLD_CAP=4

# ----------------------------------------------------------------------------
# API gateway / frontend wiring.
# ----------------------------------------------------------------------------
DRYRUN_API_PORT=8000
DRYRUN_BUREAU_PORT=8200
NEXT_PUBLIC_DRYRUN_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Agentverse / Almanac (registering the agents so ASI:One can discover & chat
# them). Create an API key at https://agentverse.ai (Profile → API Keys).
# Optional; the demo and the in-process cascade run without it. The agent
# addresses are deterministic from fixed seeds in agent_config.py — no seed env
# var is needed.
# ----------------------------------------------------------------------------
AGENTVERSE_API_KEY=
AGENTVERSE_SEARCH_URL=https://agentverse.ai/v1/search/agents
